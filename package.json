{
  "name": "nuthouse",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "prepare": "lefthook install",
    "build:runtime": "cp _shared/runtime/src/claude.mjs linear-devotee/claudecode/lib/runtime.mjs && cp _shared/runtime/src/claude.mjs saucy-status/lib/runtime.mjs",
    "check:runtime": "rc=0; for bundle in linear-devotee/claudecode/lib/runtime.mjs saucy-status/lib/runtime.mjs; do diff -q _shared/runtime/src/claude.mjs $bundle || rc=1; done; exit $rc",
    "test:runtime": "bun test _shared/runtime/tests/claude.test.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "lefthook": "2.1.6"
  }
}
