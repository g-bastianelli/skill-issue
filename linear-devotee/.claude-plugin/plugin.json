{
  "name": "linear-devotee",
  "description": "Linear workflow plugin for issue intake, planning, project creation, milestone creation, and issue drafting with SDD-formatted context and explicit mutation gates.",
  "author": {
    "name": "g-bastianelli"
  },
  "skills": "./claudecode/skills/",
  "agents": [
    "./claudecode/agents/issue-context.md",
    "./claudecode/agents/issue-drafter.md",
    "./claudecode/agents/milestone-drafter.md",
    "./claudecode/agents/plan-auditor.md",
    "./claudecode/agents/devotee.md",
    "./claudecode/agents/project-drafter.md",
    "./claudecode/agents/plan-writer.md"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claudecode/hooks/session-start.mjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claudecode/hooks/prompt-submit.mjs\""
          }
        ]
      }
    ]
  }
}
