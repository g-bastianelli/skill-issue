{
  "name": "linear-devotee",
  "description": "Linear simp dévoué — détecte ton issue Linear au début de session, set In Progress, prépare un brief SDD pour pas que tu codes comme un zinzin. Voix brainrot/simp.",
  "author": {
    "name": "g-bastianelli"
  },
  "skills": "./claudecode/skills/",
  "agents": "./claudecode/agents/",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claudecode/hooks/session-start.mjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claudecode/hooks/prompt-submit.mjs\""
          }
        ]
      }
    ]
  }
}
